{
  "name": "@jhomen368/steam-reviews-mcp",
  "version": "1.0.0",
  "description": "MCP server for querying and analyzing Steam game reviews",
  "type": "module",
  "author": "jhomen368",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/jhomen368/steam-reviews-mcp.git"
  },
  "bugs": {
    "url": "https://github.com/jhomen368/steam-reviews-mcp/issues"
  },
  "homepage": "https://github.com/jhomen368/steam-reviews-mcp#readme",
  "keywords": [
    "mcp",
    "model-context-protocol",
    "steam",
    "steam-reviews",
    "game-reviews",
    "sentiment-analysis",
    "gaming",
    "valve",
    "ai",
    "assistant"
  ],
  "mcp": {
    "server": {
      "transport": "stdio",
      "tools": [
        {
          "name": "search_steam_games",
          "description": "Search for Steam games by name or keywords with batch support"
        },
        {
          "name": "get_game_info",
          "description": "Get detailed information about Steam games including system requirements and DLC"
        },
        {
          "name": "fetch_reviews",
          "description": "Fetch user reviews for Steam games with advanced filtering options"
        },
        {
          "name": "analyze_reviews",
          "description": "Analyze Steam game reviews for sentiment, themes, and insights"
        }
      ]
    }
  },
  "bin": {
    "steam-reviews-mcp": "./build/index.js"
  },
  "files": [
    "build/",
    "README.md",
    "LICENSE"
  ],
  "main": "build/index.js",
  "scripts": {
    "build": "tsc && node -e \"require('fs').chmodSync('build/index.js', '755')\"",
    "watch": "tsc --watch",
    "prepublishOnly": "npm run build",
    "dev": "node --loader ts-node/esm src/index.ts",
    "start": "node build/index.js",
    "lint": "eslint src",
    "lint:fix": "eslint src --fix",
    "format": "prettier --write \"src/**/*.ts\"",
    "format:check": "prettier --check \"src/**/*.ts\""
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.0.4",
    "axios": "^1.7.9",
    "cheerio": "^1.2.0",
    "express": "^5.1.0",
    "natural": "^8.0.1",
    "zod": "^4.3.6"
  },
  "devDependencies": {
    "@eslint/js": "^10.0.1",
    "@types/express": "^5.0.5",
    "@types/node": "^25.0.3",
    "@typescript-eslint/eslint-plugin": "^8.56.0",
    "@typescript-eslint/parser": "^8.56.0",
    "eslint": "^10.0.1",
    "eslint-config-prettier": "^10.1.8",
    "eslint-plugin-prettier": "^5.1.3",
    "prettier": "^3.2.5",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "typescript-eslint": "^8.56.0"
  },
  "engines": {
    "node": ">=18.0.0"
  }
}
