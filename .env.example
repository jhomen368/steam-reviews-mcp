# Steam Reviews MCP Server Configuration
# Copy this file to .env and customize as needed

# ===========================================
# Cache Configuration
# ===========================================

# Enable or disable caching (default: true)
CACHE_ENABLED=true

# Cache TTL (Time To Live) in milliseconds
# Reviews cache: 15 minutes (default)
CACHE_REVIEWS_TTL=900000

# Game info cache: 2 hours (default)
CACHE_GAME_INFO_TTL=7200000

# Statistics cache: 5 minutes (default)
CACHE_STATISTICS_TTL=300000

# Analysis cache: 30 minutes (default)
CACHE_ANALYSIS_TTL=1800000

# Maximum number of items in cache (default: 1000)
CACHE_MAX_SIZE=1000

# ===========================================
# Rate Limiting
# ===========================================

# Enable or disable rate limiting (default: true)
RATE_LIMIT_ENABLED=true

# Maximum requests per minute (default: 30)
MAX_REQUESTS_PER_MINUTE=30

# ===========================================
# Server Configuration
# ===========================================

# Enable HTTP mode for debugging (default: false)
# When true, server runs as HTTP server instead of stdio
HTTP_MODE=false

# Port for HTTP mode (default: 8086)
PORT=8086

# ===========================================
# Logging
# ===========================================

# Log level: debug | info | warn | error (default: info)
LOG_LEVEL=info